    <Assign DisplayName="Get Minimum Price" sap:VirtualizedContainerService.HintSize="449.6,174.4" sap2010:WorkflowViewState.IdRef="Assign_1">
      <Assign.To>
        <OutArgument x:TypeArguments="x:Double">
          <CSharpReference x:TypeArguments="x:Double" sap2010:WorkflowViewState.IdRef="CSharpReference`1_1">double_MinimumPrice</CSharpReference>
        </OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:Double">
          <CSharpValue x:TypeArguments="x:Double" sap2010:WorkflowViewState.IdRef="CSharpValue`1_7">in_dtCoursesData.AsEnumerable().Where(row =&gt; !row.IsNull("CoursePrice")).Min(row =&gt; row.Field&lt;double&gt;("CoursePrice"))</CSharpValue>
        </InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Get Cheapest Courses Info" sap:VirtualizedContainerService.HintSize="449.6,174.4" sap2010:WorkflowViewState.IdRef="Assign_2">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">
          <CSharpReference x:TypeArguments="x:String" sap2010:WorkflowViewState.IdRef="CSharpReference`1_2">dtrow_CheapestCourses</CSharpReference>
        </OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">
          <CSharpValue x:TypeArguments="x:String" sap2010:WorkflowViewState.IdRef="CSharpValue`1_8">string.Join(", ", in_dtCoursesData.AsEnumerable().Where(row =&gt; !row.IsNull("CoursePrice") &amp;&amp; row.Field&lt;double&gt;("CoursePrice") == double_MinimumPrice).Select(row =&gt; row.Field&lt;string&gt;("CourseTitle")).ToArray())</CSharpValue>
        </InArgument>
      </Assign.Value>
    </Assign>
    <ui:MessageBox Caption="{x:Null}" ChosenButton="{x:Null}" AutoCloseAfter="00:00:00" DisplayName="Show Cheapest Courses" sap:VirtualizedContainerService.HintSize="449.6,122.4" sap2010:WorkflowViewState.IdRef="MessageBox_1">
      <ui:MessageBox.Text>
        <InArgument x:TypeArguments="x:Object">
          <CSharpValue x:TypeArguments="x:Object" sap2010:WorkflowViewState.IdRef="CSharpValue`1_4">string.Concat("Found", in_dtCoursesData.AsEnumerable().Where(row =&gt; Convert.ToDouble(row["CoursePrice"]) == double_MinimumPrice).Count().ToString(), " course(s) with the lowest price of EGP", double_MinimumPrice.ToString(), ":", Environment.NewLine, Environment.NewLine, string.Join(string.Concat(Environment.NewLine, "---------", Environment.NewLine), in_dtCoursesData.AsEnumerable().Where(row =&gt; Convert.ToDouble(row["CoursePrice"]) == double_MinimumPrice).Select(row =&gt; string.Concat("Title: ", row["CourseTitle"].ToString(), Environment.NewLine, "Author: ", row["CourseAuthor"].ToString(), Environment.NewLine, "Rating: ", row["CourseRate"].ToString()))))</CSharpValue>
        </InArgument>
      </ui:MessageBox.Text>
